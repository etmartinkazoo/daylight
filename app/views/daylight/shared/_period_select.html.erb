<% current = local_assigns[:period] || "24h" %>
<div class="flex gap-half">
  <% %w[1h 24h 7d 30d].each do |p| %>
    <%= link_to p, url_for(request.query_parameters.merge(period: p)),
          class: "btn btn--sm #{p == current ? 'btn--primary' : 'btn--outline'}",
          data: { turbo_action: "replace" } %>
  <% end %>
</div>
