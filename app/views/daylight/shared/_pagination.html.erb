<% if local_assigns[:pagination] && pagination.pages > 1 %>
  <nav class="flex items-center justify-between" style="margin-block-start: var(--size-4); font-size: 0.8125rem;">
    <span class="text-subtle">
      Page <%= pagination.page %> of <%= pagination.pages %> (<%= pagination.count %> total)
    </span>
    <div class="flex gap-half">
      <% if pagination.prev %>
        <%= link_to "← Previous", url_for(request.query_parameters.merge(page: pagination.prev)),
              class: "btn btn--sm btn--outline", data: { turbo_action: "replace" } %>
      <% end %>
      <% if pagination.next %>
        <%= link_to "Next →", url_for(request.query_parameters.merge(page: pagination.next)),
              class: "btn btn--sm btn--outline", data: { turbo_action: "replace" } %>
      <% end %>
    </div>
  </nav>
<% end %>
