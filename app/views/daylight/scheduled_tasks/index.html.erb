<%= render "daylight/shared/page_header", title: "Scheduled Tasks", actions: capture {
  link_to "Export", scheduled_tasks_export_path(request.query_parameters), class: "btn btn--sm btn--outline"
} %>

<%= render "daylight/shared/period_select", period: @period %>

<div class="grid grid--stats">
  <%= render "daylight/shared/stat_card", label: "Total", value: number_with_delimiter(@totals[:total]) %>
  <%= render "daylight/shared/stat_card", label: "Completed", value: number_with_delimiter(@totals[:completed]) %>
  <%= render "daylight/shared/stat_card", label: "Failed", value: number_with_delimiter(@totals[:failed]) %>
</div>

<%= render "daylight/shared/bar_chart", data: @volume_series %>

<% if @task_classes.any? %>
  <div class="card">
    <table class="table">
      <thead>
        <tr>
          <th>Task Class</th>
          <th><%= render "daylight/shared/sortable_header", label: "Total", column: "total", sort_column: @sort_column, sort_direction: @sort_direction %></th>
          <th>Completed</th>
          <th>Failed</th>
          <th><%= render "daylight/shared/sortable_header", label: "Avg", column: "avg_duration", sort_column: @sort_column, sort_direction: @sort_direction %></th>
          <th><%= render "daylight/shared/sortable_header", label: "Max", column: "max_duration", sort_column: @sort_column, sort_direction: @sort_direction %></th>
        </tr>
      </thead>
      <tbody>
        <% @task_classes.each do |t| %>
          <tr>
            <td class="dl-mono"><%= t[:task_class] %></td>
            <td><%= number_with_delimiter(t[:total]) %></td>
            <td><%= number_with_delimiter(t[:completed_count]) %></td>
            <td><%= number_with_delimiter(t[:failed_count]) %></td>
            <td><%= t[:avg_duration].to_i %>ms</td>
            <td><%= t[:max_duration].to_i %>ms</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <%= render "daylight/shared/empty_state", message: "No scheduled tasks found for the selected period." %>
<% end %>

<% if @failures.any? %>
  <h2 class="dl-section-title" style="margin-block-start: var(--size-6)">Recent Failures</h2>

  <div class="card">
    <table class="table">
      <thead>
        <tr>
          <th>Task Class</th>
          <th>Error Class</th>
          <th>Error Message</th>
          <th>Duration</th>
          <th>Time</th>
        </tr>
      </thead>
      <tbody>
        <% @failures.each do |f| %>
          <tr>
            <td class="dl-mono"><%= f.task_class %></td>
            <td class="dl-mono"><%= f.error_class %></td>
            <td><%= truncate(f.error_message.to_s, length: 60) %></td>
            <td><%= f.duration_ms.to_i %>ms</td>
            <td class="text-subtle"><%= f.occurred_at %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

<%= render "daylight/shared/pagination", pagination: @pagination %>
