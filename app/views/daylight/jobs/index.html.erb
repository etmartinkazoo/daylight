<%= render "daylight/shared/page_header", title: "Jobs", actions: capture {
  link_to "Export CSV", jobs_export_path(period: @period), class: "btn btn--sm btn--outline"
} %>

<%= render "daylight/shared/period_select", period: @period %>

<div class="grid grid--4" style="margin-block-start: var(--size-4)">
  <%= render "daylight/shared/stat_card", label: "Total", value: number_with_delimiter(@totals[:total]) %>
  <%= render "daylight/shared/stat_card", label: "Completed", value: number_with_delimiter(@totals[:completed]) %>
  <%= render "daylight/shared/stat_card", label: "Failed", value: number_with_delimiter(@totals[:failed]) %>
</div>

<div style="margin-block-start: var(--size-4)">
  <%= render "daylight/shared/bar_chart", data: @volume_series, height: "10rem" %>
</div>

<div class="card" style="margin-block-start: var(--size-4)">
  <h2 class="card__title">Job Classes</h2>

  <% if @job_classes.any? %>
    <div class="table-scroll">
      <table class="table">
        <thead>
          <tr>
            <th>Job Class</th>
            <th class="text-end"><%= render "daylight/shared/sortable_header", label: "Total", column: "total", sort_column: @sort_column, sort_direction: @sort_direction %></th>
            <th class="text-end">Completed</th>
            <th class="text-end">Failed</th>
            <th class="text-end">Queued</th>
            <th class="text-end"><%= render "daylight/shared/sortable_header", label: "Avg", column: "avg_duration", sort_column: @sort_column, sort_direction: @sort_direction %></th>
            <th class="text-end"><%= render "daylight/shared/sortable_header", label: "Max", column: "max_duration", sort_column: @sort_column, sort_direction: @sort_direction %></th>
          </tr>
        </thead>
        <tbody>
          <% @job_classes.each do |job| %>
            <tr>
              <td class="dl-mono"><%= job[:job_class] %></td>
              <td class="text-end"><%= number_with_delimiter(job[:total]) %></td>
              <td class="text-end"><%= number_with_delimiter(job[:completed_count]) %></td>
              <td class="text-end"><%= number_with_delimiter(job[:failed_count]) %></td>
              <td class="text-end"><%= number_with_delimiter(job[:queued_count]) %></td>
              <td class="text-end"><%= job[:avg_duration].to_i %>ms</td>
              <td class="text-end"><%= job[:max_duration].to_i %>ms</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <%= render "daylight/shared/empty_state", message: "No jobs recorded for this period." %>
  <% end %>
</div>

<%= render "daylight/shared/pagination", pagy: @pagy if defined?(@pagy) %>

<div class="card" style="margin-block-start: var(--size-6)">
  <h2 class="card__title">Recent Failures</h2>

  <% if @failures.any? %>
    <div class="table-scroll">
      <table class="table">
        <thead>
          <tr>
            <th>Job Class</th>
            <th>Queue</th>
            <th>Error Class</th>
            <th>Error Message</th>
            <th class="text-end">Duration</th>
            <th>When</th>
          </tr>
        </thead>
        <tbody>
          <% @failures.each do |job| %>
            <tr>
              <td class="dl-mono"><%= job[:job_class] %></td>
              <td><%= job[:queue] %></td>
              <td class="dl-mono"><%= job[:error_class] %></td>
              <td><%= truncate(job[:error_message].to_s, length: 80) %></td>
              <td class="text-end"><%= job[:duration_ms].to_i %>ms</td>
              <td class="text-subtle"><%= time_ago_in_words(job[:occurred_at]) %> ago</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <%= render "daylight/shared/empty_state", message: "No failures recorded for this period." %>
  <% end %>
</div>

<% if @solid_queue.present? %>
  <div class="card" style="margin-block-start: var(--size-6)">
    <h2 class="card__title">SolidQueue Status</h2>

    <div class="grid grid--4" style="margin-block-start: var(--size-2)">
      <% @solid_queue.each do |key, value| %>
        <%= render "daylight/shared/stat_card", label: key.to_s.humanize, value: number_with_delimiter(value) %>
      <% end %>
    </div>
  </div>
<% end %>
