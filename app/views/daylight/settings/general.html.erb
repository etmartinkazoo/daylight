<%= render layout: "daylight/settings/layout", locals: {
      active: "general",
      section_label: "General",
      section_description: "Connect Daylight to your repository."
    } do %>
  <%= form_with url: settings_path, method: :patch, data: { turbo: false }, class: "flex flex-col gap" do |f| %>
    <%= hidden_field_tag :section, "general" %>

    <div class="card">
      <h3 class="card__title">GitHub</h3>
      <div class="flex flex-col gap-1">
        <div class="flex flex-col gap-half">
          <label for="settings_github_repo_url" class="text-sm font-medium">Repository URL</label>
          <input type="text" name="settings[github_repo_url]" id="settings_github_repo_url" value="<%= @settings[:github_repo_url] %>" class="input">
          <p class="text-xs text-subtle">Full URL to your GitHub repository</p>
        </div>
        <div class="flex flex-col gap-half">
          <label for="settings_github_default_branch" class="text-sm font-medium">Default Branch</label>
          <input type="text" name="settings[github_default_branch]" id="settings_github_default_branch" value="<%= @settings[:github_default_branch] %>" class="input">
        </div>
      </div>
    </div>

    <div>
      <button type="submit" class="btn btn--primary">Save</button>
    </div>
  <% end %>
<% end %>
