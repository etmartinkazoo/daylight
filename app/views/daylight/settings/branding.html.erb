<%= render layout: "daylight/settings/layout", locals: {
      active: "branding",
      section_label: "Branding",
      section_description: "Customize how Daylight appears in this app."
    } do %>
  <%= form_with url: settings_path, method: :patch, class: "flex flex-col gap" do |f| %>
    <%= hidden_field_tag :section, "branding" %>

    <div class="card">
      <h3 class="card__title">Identity</h3>
      <div class="flex flex-col gap-1">
        <div class="flex flex-col gap-half">
          <label for="settings_app_name" class="text-sm font-medium">App Name</label>
          <input type="text" name="settings[app_name]" id="settings_app_name" value="<%= @settings[:app_name] %>" class="input" placeholder="Daylight">
          <p class="text-xs text-subtle">Appears in the browser title and sidebar.</p>
        </div>

        <div class="flex flex-col gap-half">
          <label for="settings_app_icon" class="text-sm font-medium">Icon</label>
          <input type="text" name="settings[app_icon]" id="settings_app_icon" value="<%= @settings[:app_icon] %>" class="input" maxlength="4" placeholder="☀">
          <p class="text-xs text-subtle">A single character or emoji shown next to the app name.</p>
        </div>

        <div class="flex flex-col gap-half">
          <label for="settings_app_logo_url" class="text-sm font-medium">Logo URL</label>
          <input type="url" name="settings[app_logo_url]" id="settings_app_logo_url" value="<%= @settings[:app_logo_url] %>" class="input" placeholder="https://…/logo.svg">
          <p class="text-xs text-subtle">If set, replaces the icon + name in the sidebar.</p>
        </div>
      </div>
    </div>

    <div class="card">
      <h3 class="card__title">Colors</h3>
      <div class="flex items-center gap-1">
        <input type="color"
               name="settings[primary_color]"
               id="settings_primary_color"
               value="<%= @settings[:primary_color] %>"
               class="dl-color-input"
               oninput="document.getElementById('settings_primary_color_text').value = this.value">
        <input type="text"
               id="settings_primary_color_text"
               value="<%= @settings[:primary_color] %>"
               class="input dl-mono"
               style="max-inline-size: 10rem"
               pattern="#[0-9a-fA-F]{6}"
               oninput="document.getElementById('settings_primary_color').value = this.value; document.querySelector('input[name=\'settings[primary_color]\']').value = this.value">
      </div>
      <p class="text-xs text-subtle" style="margin-block-start: var(--size-2)">Primary color is used for active nav, primary buttons, and the sidebar icon.</p>
    </div>

    <div class="card">
      <h3 class="card__title">Preview</h3>
      <div class="dl-brand-preview">
        <div class="dl-brand-preview__row">
          <span class="sidebar-brand__icon"><%= @settings[:app_icon].presence || "☀" %></span>
          <strong><%= @settings[:app_name].presence || "Daylight" %></strong>
        </div>
        <div class="dl-brand-preview__row">
          <button type="button" class="btn btn--primary">Primary button</button>
          <span class="sidebar-menu__item" aria-current="page" style="display:inline-flex; inline-size: auto">Active nav</span>
        </div>
      </div>
    </div>

    <div>
      <button type="submit" class="btn btn--primary">Save branding</button>
    </div>
  <% end %>
<% end %>
