<%= render layout: "daylight/settings/layout", locals: {
      active: "ai",
      section_label: "AI",
      section_description: "API keys, model selection, and auto-investigation settings."
    } do %>
  <%= form_with url: settings_path, method: :patch, data: { turbo: false }, class: "flex flex-col gap" do |f| %>
    <%= hidden_field_tag :section, "ai" %>

    <div class="card">
      <h3 class="card__title">Models</h3>
      <p class="text-xs text-subtle" style="margin-block-end: var(--size-3);">Use a fast, cheap model for investigation/triage and a more capable model for generating code fixes. Only models whose API key is configured above will work.</p>
      <div class="flex flex-col gap-1">
        <div class="flex flex-col gap-half">
          <label for="settings_ai_investigation_model" class="text-sm font-medium">Investigation Model</label>
          <select name="settings[ai_investigation_model]" id="settings_ai_investigation_model" class="input">
            <% Daylight::AI::MODELS.each do |model| %>
              <option value="<%= model[:id] %>" <%= "selected" if @settings[:ai_investigation_model] == model[:id] %>>
                <%= model[:label] %> (<%= model[:provider] %>)
              </option>
            <% end %>
          </select>
          <p class="text-xs text-subtle">Used for error/incident triage and root cause analysis. A smaller model like Gemini Flash, GPT-4.1 Mini, or Claude Haiku works well here.</p>
        </div>
        <div class="flex flex-col gap-half">
          <label for="settings_ai_solution_model" class="text-sm font-medium">Solution Model</label>
          <select name="settings[ai_solution_model]" id="settings_ai_solution_model" class="input">
            <% Daylight::AI::MODELS.each do |model| %>
              <option value="<%= model[:id] %>" <%= "selected" if @settings[:ai_solution_model] == model[:id] %>>
                <%= model[:label] %> (<%= model[:provider] %>)
              </option>
            <% end %>
          </select>
          <p class="text-xs text-subtle">Used for generating code fixes and GitHub branches. A more capable model like Gemini Pro, GPT-4.1, or Claude Sonnet/Opus produces better results.</p>
        </div>
        <div class="flex flex-col gap-half">
          <label for="settings_default_ai_model" class="text-sm font-medium">Chat Model</label>
          <select name="settings[default_ai_model]" id="settings_default_ai_model" class="input">
            <% Daylight::AI::MODELS.each do |model| %>
              <option value="<%= model[:id] %>" <%= "selected" if @settings[:default_ai_model] == model[:id] %>>
                <%= model[:label] %> (<%= model[:provider] %>)
              </option>
            <% end %>
          </select>
          <p class="text-xs text-subtle">Used for interactive AI chat and solution refinement conversations.</p>
        </div>
      </div>
    </div>

    <div class="card">
      <h3 class="card__title">API Keys</h3>
      <div class="flex flex-col gap-1">
        <div class="flex flex-col gap-half">
          <label for="settings_openai_api_key" class="text-sm font-medium">OpenAI API Key</label>
          <input type="password" name="settings[openai_api_key]" id="settings_openai_api_key" value="<%= @settings[:openai_api_key] %>" class="input" placeholder="sk-...">
          <p class="text-xs text-subtle">For GPT-4.1, o3, and o4-mini models.</p>
        </div>
        <div class="flex flex-col gap-half">
          <label for="settings_anthropic_api_key" class="text-sm font-medium">Anthropic API Key</label>
          <input type="password" name="settings[anthropic_api_key]" id="settings_anthropic_api_key" value="<%= @settings[:anthropic_api_key] %>" class="input" placeholder="sk-ant-...">
          <p class="text-xs text-subtle">For Claude Haiku, Sonnet, and Opus models.</p>
        </div>
        <div class="flex flex-col gap-half">
          <label for="settings_gemini_api_key" class="text-sm font-medium">Gemini API Key</label>
          <input type="password" name="settings[gemini_api_key]" id="settings_gemini_api_key" value="<%= @settings[:gemini_api_key] %>" class="input">
          <p class="text-xs text-subtle">For Gemini 2.5 Flash and Pro models.</p>
        </div>
      </div>
    </div>

    <div class="card">
      <h3 class="card__title">GitHub</h3>
      <div class="flex flex-col gap-1">
        <div class="flex flex-col gap-half">
          <label for="settings_github_api_token" class="text-sm font-medium">Personal Access Token</label>
          <input type="password" name="settings[github_api_token]" id="settings_github_api_token" value="<%= @settings[:github_api_token] %>" class="input">
          <p class="text-xs text-subtle">Used to fetch source code for AI analysis and to open pull requests for proposed fixes.</p>
        </div>
      </div>
    </div>

    <div class="card">
      <h3 class="card__title">Auto-Investigation</h3>
      <div class="flex flex-col gap-1">
        <div class="flex items-center gap-half">
          <input type="hidden" name="settings[auto_investigate_errors]" value="false">
          <input type="checkbox" name="settings[auto_investigate_errors]" id="settings_auto_investigate_errors" value="true"
            <%= "checked" if @settings[:auto_investigate_errors] == "true" %>>
          <label for="settings_auto_investigate_errors" class="text-sm font-medium">Investigate new errors and incidents automatically</label>
        </div>
        <p class="text-xs text-subtle">When enabled, the AI agent will automatically analyze every new error (first occurrence) and every new incident, proposing a root cause and fix. Requires at least one API key configured above.</p>

        <div class="flex items-center gap-half" style="margin-block-start: var(--size-2);">
          <input type="hidden" name="settings[auto_push_fix_branches]" value="false">
          <input type="checkbox" name="settings[auto_push_fix_branches]" id="settings_auto_push_fix_branches" value="true"
            <%= "checked" if @settings[:auto_push_fix_branches] == "true" %>>
          <label for="settings_auto_push_fix_branches" class="text-sm font-medium">Push suggested fix branches to GitHub</label>
        </div>
        <p class="text-xs text-subtle">When enabled and a GitHub token + repo are configured, the AI will automatically create a branch with the proposed fix after investigating an error. Branches are prefixed with <code>daylight/fix-</code> for easy identification.</p>
      </div>
    </div>

    <div class="card">
      <h3 class="card__title">Investigate All</h3>
      <div class="flex flex-col gap-half">
        <p class="text-xs text-subtle">Run the AI agent on all open errors and incidents that haven't been investigated yet.</p>
        <%= button_to "Investigate All Uninvestigated", settings_investigate_all_path, method: :post, data: { turbo: false }, class: "btn btn--sm btn--primary", style: "align-self: flex-start;" %>
      </div>
    </div>

    <div class="card">
      <h3 class="card__title">Context</h3>
      <div class="flex flex-col gap-half">
        <label for="settings_ai_context_notes" class="text-sm font-medium">AI Context Notes</label>
        <textarea name="settings[ai_context_notes]" id="settings_ai_context_notes" class="input" rows="6" placeholder="e.g. Rails 8 app, SQLite database, ActiveRecord multi-tenanted, ERB views with Hotwire/Turbo, SolidQueue for background jobs, Propshaft asset pipeline."><%= @settings[:ai_context_notes] %></textarea>
        <p class="text-xs text-subtle">Describe your app's stack and architecture so the AI can give more relevant analysis. Include framework version, database, templating, background jobs, and any notable patterns or conventions.</p>
      </div>
    </div>

    <div>
      <button type="submit" class="btn btn--primary">Save</button>
    </div>
  <% end %>
<% end %>
