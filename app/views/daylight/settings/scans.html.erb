<%= render layout: "daylight/settings/layout", locals: {
      active: "scans",
      section_label: "Scans",
      section_description: "Automated performance and security scans."
    } do %>
  <%= form_with url: settings_path, method: :patch, data: { turbo: false }, class: "flex flex-col gap" do |f| %>
    <%= hidden_field_tag :section, "scans" %>

    <div class="card">
      <h3 class="card__title">Automated scans</h3>
      <div class="flex flex-col gap-1">
        <div class="flex items-center gap-half">
          <input type="hidden" name="settings[performance_scan_enabled]" value="0">
          <input type="checkbox" name="settings[performance_scan_enabled]" id="settings_performance_scan_enabled" value="1" <%= "checked" if ActiveModel::Type::Boolean.new.cast(@settings[:performance_scan_enabled]) %>>
          <label for="settings_performance_scan_enabled" class="text-sm font-medium">Performance scan</label>
        </div>
        <div class="flex items-center gap-half">
          <input type="hidden" name="settings[security_scan_enabled]" value="0">
          <input type="checkbox" name="settings[security_scan_enabled]" id="settings_security_scan_enabled" value="1" <%= "checked" if ActiveModel::Type::Boolean.new.cast(@settings[:security_scan_enabled]) %>>
          <label for="settings_security_scan_enabled" class="text-sm font-medium">Security scan</label>
        </div>
        <div class="flex items-center gap-half">
          <input type="hidden" name="settings[solutions_scan_enabled]" value="0">
          <input type="checkbox" name="settings[solutions_scan_enabled]" id="settings_solutions_scan_enabled" value="1" <%= "checked" if ActiveModel::Type::Boolean.new.cast(@settings[:solutions_scan_enabled]) %>>
          <label for="settings_solutions_scan_enabled" class="text-sm font-medium">Solutions scan</label>
        </div>
      </div>
      <div style="margin-block-start: var(--size-3)">
        <button type="submit" class="btn btn--primary">Save</button>
      </div>
    </div>
  <% end %>

  <% if @performance_issues.any? %>
    <div class="card" style="margin-block-start: var(--size-4)">
      <h3 class="card__title">Performance issues</h3>
      <table class="table">
        <thead>
          <tr><th>Title</th><th>Severity</th><th>Source</th><th>Status</th><th></th></tr>
        </thead>
        <tbody>
          <% @performance_issues.each do |issue| %>
            <tr>
              <td><%= issue.title %></td>
              <td><%= render "daylight/shared/status_badge", status: issue.severity %></td>
              <td class="dl-mono"><%= issue.source_location %></td>
              <td><%= render "daylight/shared/status_badge", status: issue.status %></td>
              <td>
                <% unless issue.status == "dismissed" %>
                  <%= button_to "Dismiss", settings_performance_issue_path(issue.id), method: :patch, params: { status: "dismissed" }, class: "btn btn--sm btn--ghost" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <% if @security_issues.any? %>
    <div class="card" style="margin-block-start: var(--size-4)">
      <h3 class="card__title">Security issues</h3>
      <table class="table">
        <thead>
          <tr><th>Title</th><th>Severity</th><th>Confidence</th><th>File</th><th>Status</th><th></th></tr>
        </thead>
        <tbody>
          <% @security_issues.each do |issue| %>
            <tr>
              <td><%= issue.title %></td>
              <td><%= render "daylight/shared/status_badge", status: issue.severity %></td>
              <td><%= issue.confidence %></td>
              <td class="dl-mono"><%= issue.file_path %></td>
              <td><%= render "daylight/shared/status_badge", status: issue.status %></td>
              <td>
                <% unless issue.status == "dismissed" %>
                  <%= button_to "Dismiss", settings_security_issue_path(issue.id), method: :patch, params: { status: "dismissed" }, class: "btn btn--sm btn--ghost" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
<% end %>
