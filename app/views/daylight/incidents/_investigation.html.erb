<div id="<%= dom_id(incident, :investigation) %>"
  <% if incident.status == "investigating" %>
    data-controller="poll"
    data-poll-url-value="<%= ai_status_incident_path(incident.id) %>"
    data-poll-interval-value="3000"
    data-poll-pending
  <% end %>>
  <div class="dl-section">
    <div class="card">
      <div class="card__header">
        <h2 class="card__title">Investigation</h2>
        <% if incident.status == "investigating" %>
          <span class="badge badge--ai-pending">Investigating</span>
        <% elsif Daylight::AI.configured? %>
          <%= button_to(incident.investigation.present? ? "Re-investigate" : "Investigate",
                investigate_incident_path(incident.id), method: :post,
                class: "btn btn--sm btn--primary") %>
        <% end %>
      </div>
      <% if incident.status == "investigating" %>
        <div class="flex items-center gap-half" style="padding: var(--size-2) 0;">
          <span class="text-sm text-subtle">AI is investigating this incident...</span>
        </div>
      <% elsif incident.investigation.present? %>
        <div style="font-size: 0.875rem; line-height: 1.6; white-space: pre-wrap;"><%= incident.investigation %></div>
      <% else %>
        <p class="text-xs text-subtle">No AI investigation yet. Click Investigate to analyze this incident.</p>
      <% end %>
    </div>
  </div>
</div>
