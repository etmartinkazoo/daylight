<% content_for(:title) { "Incidents - Daylight" } %>

<%= render "daylight/shared/page_header", title: "Incidents" %>

<%= render "daylight/shared/tabs", current: @status, tabs: [
  { label: "Open", value: "open", path: incidents_path(status: "open"), count: @counts["open"] },
  { label: "All",  value: "all",  path: incidents_path(status: "all"),  count: @counts.values.sum }
] %>

<div class="dl-filters">
  <%= render "daylight/shared/period_select", period: @period %>
</div>

<div class="dl-section">
  <%= render "daylight/shared/bar_chart", data: @incident_series %>
</div>

<% if @incidents.any? %>
  <div style="display: grid; gap: var(--size-4);">
    <% @incidents.each do |incident| %>
      <%= link_to incident_path(incident.id), style: "text-decoration: none; color: inherit;" do %>
        <div class="card" style="transition: border-color 150ms; cursor: pointer;"
             onmouseenter="this.style.borderColor='var(--color-primary)'"
             onmouseleave="this.style.borderColor=''">
          <div class="flex items-center gap-half" style="margin-block-end: var(--size-2);">
            <h3 style="font-size: 0.9375rem; font-weight: 600; flex: 1; min-width: 0;">
              <%= incident.title %>
            </h3>
            <span class="badge badge--<%= incident.severity %>"><%= incident.severity %></span>
            <%= render "daylight/shared/status_badge", status: incident.status %>
            <% if incident.status == "investigating" %>
              <span class="badge badge--ai-pending">AI</span>
            <% elsif incident.investigation.present? %>
              <span class="badge badge--ai">AI</span>
            <% end %>
          </div>

          <% if incident.summary.present? %>
            <p class="text-subtle text-sm" style="margin-block-end: var(--size-3); line-height: 1.5;">
              <%= truncate(incident.summary.to_s, length: 200) %>
            </p>
          <% end %>

          <div class="flex items-center gap-half text-xs text-subtle">
            <span class="badge badge--default"><%= incident.incident_type %></span>
            <span><%= time_ago_in_words(incident.started_at) + " ago" %></span>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <%= render "daylight/shared/empty_state", message: "No incidents found." %>
<% end %>
