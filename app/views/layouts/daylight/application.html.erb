<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Daylight</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= action_cable_meta_tag if respond_to?(:action_cable_meta_tag) %>

  <% bundle_path = Daylight::Engine.root.join("app", "assets", "builds") %>
  <% if (css = Dir.glob(bundle_path.join("daylight-*.css")).first) %>
    <link rel="stylesheet" href="<%= "/daylight/assets/#{File.basename(css)}" %>">
  <% end %>
  <% if (js = Dir.glob(bundle_path.join("daylight-*.js")).first) %>
    <script type="module" src="<%= "/daylight/assets/#{File.basename(js)}" %>"></script>
  <% end %>
</head>
<body>
  <%= yield %>
</body>
</html>
